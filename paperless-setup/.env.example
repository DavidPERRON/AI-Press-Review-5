# -----------------------------------------------------------------------------
# Paperless-ngx stack configuration
# Copy to .env and edit.
# -----------------------------------------------------------------------------

# Where Paperless stores its data (postgres, media, index).
# Set this to your SSD path, e.g. /Volumes/SSD2TB/paperless-data
PAPERLESS_DATA_ROOT=./data

# Folder that Paperless watches. Drop PDFs here and they get ingested.
# You can point this to a subset of your organized tree after `mac-organizer apply`.
PAPERLESS_CONSUME_DIR=./consume

# Admin account (created on first start).
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme

# DB password.
PAPERLESS_DB_PASSWORD=paperless

# OCR languages (Tesseract codes). Add/remove as needed.
PAPERLESS_OCR_LANGUAGE=fra+eng
PAPERLESS_TIME_ZONE=Europe/Paris

# Public URL (keep localhost for local-only access).
PAPERLESS_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# DeepInfra (used by the mac-organizer CLI, not by Paperless itself).
# -----------------------------------------------------------------------------
DEEPINFRA_API_KEY=
